COMPOSE_PROJECT_NAME="jazz-stack"

# Oracle 19c Database
# Pull from Oracle Container Registry (requires login: container-registry.oracle.com)
# Or use gvenzl/oracle-xe:21-slim for a lighter alternative
ORACLE_IMAGE="container-registry.oracle.com/database/enterprise:19.3.0.0"
# Oracle usernames are stored uppercase internally. Use ALLCAPS to avoid confusion.
ORACLE_USER="JAZZ_DBA"
# Password rules (apply to ALL passwords in this file):
#   - At least 8 characters
#   - At least 1 uppercase letter, 1 lowercase letter, and 1 digit
#   - No spaces, no special characters: ! @ # $ % ^ & * ' " ` \ ; etc.
#   - Use word-verb phrases like "OrangeTiger42runs" or "BlueJazz19goes"
#   - These pass through bash, SQL, JDBC URLs, and XML — punctuation breaks quoting
#   - Oracle enforces these rules for SYS/SYSTEM/PDBADMIN passwords
ORACLE_PASSWORD="CHANGE_ME"
ORACLE_SYS_PASSWORD="CHANGE_ME"
ORACLE_PDB="JAZZPDB"
ORACLE_FQDN="database.local"
ORACLE_PORT=1521

# Jazz ELM 7.0.3 + iFix021
# Host these files on an HTTP-accessible URL (e.g., GCS bucket)
# Download originals from IBM Passport Advantage
JAZZ_DISTRO_URL="https://storage.googleapis.com/YOUR_BUCKET/JTS-DCM-CCM-QM-RM-JRS-ENI-repo-7.0.3.zip"
IBMWEBINSTALLER_DISTRO_URL="https://storage.googleapis.com/YOUR_BUCKET/ELM-Web-Installer-Linux-7.0.3.zip"
DM_DISTRO_URL="https://storage.googleapis.com/YOUR_BUCKET/Rhapsody-DM-Servers-6.0.6.1.zip"
JAZZ_JAS_URL="https://storage.googleapis.com/YOUR_BUCKET/JazzAuthServer-offering-repo-7.0.3.zip"
JAZZ_IFIX_URL="https://storage.googleapis.com/YOUR_BUCKET/ELM_703_iFix021.zip"

CLM_FQDN="your-elm-server.example.com"
CLM_PORT=9443
# Jazz username is not stored in Oracle — lowercase is fine here
JAZZ_USER="jazz_admin"
# Same password rules as above — 8+ chars, upper+lower+digit, no special chars
JAZZ_ADMIN_PASSWORD="CHANGE_ME"

JAS_HTTPS_PORT=9643
JAS_HTTP_PORT=9280
LDAP_FQDN="your-ldap-server.example.com"
LDAP_PORT=389
LDAP_BASE_DN="dc=example,dc=com"

ACME_EMAIL="you@example.com"
